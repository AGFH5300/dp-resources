# Supabase project URL and anon key used by server/client auth helpers.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only key for protected profile approval and durable activity writes. Never expose in browser.
SUPABASE_SERVICE_ROLE_KEY=

# Root private Google Drive folder ID shared with the service account below.
GOOGLE_DRIVE_FOLDER_ID=
# Service account email and private key. Store newlines as \n in Vercel/local env values.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Comma-separated emails that are treated as admins server-side.
ADMIN_EMAILS=
