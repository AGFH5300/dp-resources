{
  "name": "dp-resources",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:hot": "concurrently -s last -n \"NEXT,WARM\" -c \"cyan,magenta\" \"next dev -p 5000\" \"node scripts/warmup-dev.mjs\"",
    "build": "next build",
    "start": "next start",
    "pdf-previews:worker": "node scripts/pdf-preview-worker.mjs",
    "pdf-previews:queue": "node scripts/queue-pdf-previews.mjs",
    "question-bank:import": "node scripts/import-question-bank.mjs",
    "question-bank:audit": "node scripts/import-question-bank.mjs --mode audit",
    "question-bank:dry-run": "node scripts/import-question-bank.mjs --mode dry-run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@radix-ui/react-select": "^2.3.2",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.56.0",
    "@tailwindcss/postcss": "^4.1.10",
    "@vue-office/pptx": "^1.0.1",
    "docx-preview": "^0.3.7",
    "dompurify": "^3.4.12",
    "fast-glob": "^3.3.3",
    "googleapis": "^173.0.0",
    "jszip": "^3.10.1",
    "katex": "^0.16.22",
    "lucide-react": "^1.22.0",
    "next": "^15.4.0",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwindcss": "^4.1.10",
    "vue": "^3.5.39",
    "vue-demi": "^0.14.10"
  },
  "devDependencies": {
    "@types/katex": "^0.16.7",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "concurrently": "^9.2.1",
    "eslint": "^9.29.0",
    "eslint-config-next": "^15.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "overrides": {
    "brace-expansion@^2.0.0": "2.1.2",
    "postcss": "8.5.16"
  }
